# ----------------------------------------------------------------------------
# IndQA Client Environment (Vite)
# Copy to ".env" and adjust for your deployment:  cp .env.example .env
# Only variables prefixed with VITE_ are exposed to the browser bundle.
# ----------------------------------------------------------------------------

# Base URL of the backend REST API.
# Leave as "/api" in local dev (Vite proxies it to the server — see vite.config.js).
# In production set the full URL, e.g. https://indqa-api.onrender.com/api
VITE_API_URL=/api

# Base URL of the Socket.IO server.
# Leave empty in local dev (the Vite proxy forwards /socket.io to the server).
# In production set the server origin, e.g. https://indqa-api.onrender.com
VITE_SOCKET_URL=
