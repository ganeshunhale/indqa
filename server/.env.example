# ----------------------------------------------------------------------------
# IndQA Server Environment Configuration
# Copy this file to ".env" and fill in your own values:  cp .env.example .env
# NEVER commit your real .env file — it is gitignored for a reason.
# ----------------------------------------------------------------------------

# MongoDB Atlas connection string (free M0 cluster).
# Get it from: MongoDB Atlas → Cluster → Connect → Drivers.
# The database must have an Atlas Vector Search index named "embedding_index"
# (768 dimensions, cosine similarity) on the knowledgechunks collection.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/indqa

# Secret used to sign JWT auth tokens.
# Use a long random string (>= 32 characters). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Google Gemini API key (free at https://aistudio.google.com/apikey).
# Used for both embeddings (gemini-embedding-001) and answer generation (gemini-2.5-flash).
GEMINI_API_KEY=your-gemini-api-key-here

# ---- Server config (optional — sensible defaults shown) ----

# Port the API/Socket.IO server listens on.
PORT=4000

# URL of the frontend, used for CORS + Socket.IO origin allow-list.
CLIENT_URL=http://localhost:5173

# "development" exposes error details to clients; use "production" when deployed.
NODE_ENV=development

# ---- RAG / conversation-context tuning (optional — sensible defaults shown) ----

# Recent messages (prior turns) fed back to the model so follow-up questions
# like "who is he?" resolve against earlier turns in the same chat. 6 ≈ 3 turns.
# Set to 0 to disable conversation memory (single-turn behavior).
RAG_HISTORY_MESSAGES=6

# Per-message character cap for the history block, so one long answer can't
# blow up the prompt (and token cost).
RAG_HISTORY_CHAR_LIMIT=600
